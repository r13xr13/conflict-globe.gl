# Discord Bot Token
DISCORD_BOT_TOKEN=your_bot_token_here

# Conflict Globe API URL (use Railway URL in production)
CONFLICT_GLOBE_API=https://your-railway-app.up.railway.app/api/conflicts

# Ollama API (local or remote)
OLLAMA_BASE_URL=http://localhost:11434

# Channel IDs (get from Discord)
LIVE_UPDATES_CHANNEL_ID=your_live_updates_channel_id
THREAT_ALERTS_CHANNEL_ID=your_threat_alerts_channel_id
GENERAL_CHANNEL_ID=your_general_channel_id
DEV_CHANNEL_ID=your_dev_channel_id
